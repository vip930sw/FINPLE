{
  "name": "portfolio-lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "prebuild": "node scripts/verify-ai-analysis-build.cjs prebuild",
    "build": "vite build && node scripts/verify-ai-analysis-build.cjs postbuild",
    "preview": "vite preview --port 4173 --strictPort",
    "lint": "eslint .",
    "check:frontend": "npm run build",
    "check:ai-production": "node scripts/check-ai-analysis-production.mjs",
    "check:scenario-data": "node scripts/verify-scenario-data-coverage.cjs",
    "check:scenario-monthly-input": "node scripts/verify-scenario-monthly-input.cjs && node --test scripts/verify-scenario-monthly-input.test.cjs",
    "check:scenario-readiness": "node scripts/generate-scenario-monthly-readiness.cjs --check",
    "check:scenario-refetch-plan": "node scripts/generate-scenario-monthly-refetch-plan.cjs --check",
    "check:scenario-p0-manifest": "node scripts/generate-scenario-p0-monthly-cache-manifest.cjs --check",
    "check:scenario-p0-dry-run": "node scripts/generate-scenario-p0-cache-dry-run.cjs --check",
    "check:scenario-p0-source-policy": "node scripts/generate-scenario-p0-source-policy-matrix.cjs --check",
    "check:scenario-p0-source-approval": "node scripts/generate-scenario-p0-source-approval-requirements.cjs --check",
    "check:scenario-p0-source-decision": "node scripts/generate-scenario-p0-source-approval-decision-record.cjs --check",
    "check:scenario-p0-writer-gate": "node scripts/generate-scenario-p0-cache-writer-gate.cjs --check",
    "check:scenario-metrics": "node --test server/src/services/scenario/*.test.js"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
