# Frontend production env for Vercel
# VITE_ variables are visible in the browser. Do not put secrets here.
VITE_FINPLE_API_BASE_URL=https://YOUR_RENDER_SERVICE.onrender.com/api
VITE_FINPLE_ASSET_PROVIDER=backend
VITE_FINPLE_BACKEND_TIMEOUT_MS=12000
VITE_FINPLE_AI_ANALYSIS_TIMEOUT_MS=60000
VITE_FINPLE_BULK_LOOKUP_DELAY_MS=1200
