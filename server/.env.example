# FINPLE Backend Environment Example
# 파일명 예시: server/.env

PORT=5050

# 로컬 프론트 주소입니다.
# 여러 도메인을 허용하려면 쉼표로 구분합니다.
# 예: http://localhost:5173,https://finple-test.vercel.app
CORS_ORIGIN=http://localhost:5173

# mock | alpha_vantage
ASSET_DATA_PROVIDER=mock

# Step 113-3A: AI 분석은 기본 mock 모드입니다. 외부 AI API 키를 사용하지 않습니다.
FINPLE_AI_ANALYSIS_MODE=mock
FINPLE_AI_ANALYSIS_PROVIDER=none

# Step 113-4C: live provider 사용 시에만 서버 환경변수로 설정합니다.
# 브라우저에 노출되는 VITE_ 변수로 API key를 넣지 마세요.
OPENAI_API_KEY=
FINPLE_AI_OPENAI_MODEL=gpt-5.1
FINPLE_AI_OPENAI_TIMEOUT_MS=20000
FINPLE_AI_OPENAI_MAX_OUTPUT_TOKENS=2200

# Alpha Vantage 연결 시 필요합니다. API 키는 프론트엔드에 넣지 말고 서버 .env에만 보관하세요.
ALPHA_VANTAGE_API_KEY=

# FINPLE 화면은 원화 기준이므로 기본값은 KRW입니다.
ASSET_PRICE_CURRENCY=KRW
DEFAULT_USD_KRW_RATE=1350

# API 호출량을 줄이기 위해 기본은 false입니다.
ALPHA_VANTAGE_FETCH_FX=false
ALPHA_VANTAGE_FETCH_OVERVIEW=false

# 가격 조회 캐시 시간입니다. 기본 24시간.
ASSET_CACHE_TTL_MS=86400000

# Step 45: 서버 DB 연결 준비
# 비워두면 기존처럼 localStorage 중심으로 사용합니다.
# PostgreSQL 연결 시 아래 값을 설정하세요.
DATABASE_URL=
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000

# 로그인 기능 전까지 사용하는 개발용 사용자입니다.
FINPLE_DEV_USER_ID=00000000-0000-4000-8000-000000000001
FINPLE_DEV_USER_EMAIL=dev@finple.local
FINPLE_DEV_USER_NAME=FINPLE Demo User
